<Window x:Class="NetScan.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="N3tSc4n" Icon="app.ico" Height="680" Width="1150"
        MinHeight="400" MinWidth="700"
        Background="#1E1E2E"
        Foreground="#CDD6F4"
        FontFamily="Segoe UI"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        StateChanged="Window_StateChanged">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="38"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>

        <!-- ── Brushes ─────────────────────────────── -->
        <SolidColorBrush x:Key="SurfaceBrush"  Color="#313244"/>
        <SolidColorBrush x:Key="AccentBrush"   Color="#89B4FA"/>
        <SolidColorBrush x:Key="SubtleBrush"   Color="#585B70"/>
        <SolidColorBrush x:Key="TextBrush"     Color="#CDD6F4"/>

        <!-- ── Toolbar button ──────────────────────── -->
        <Style x:Key="DarkButton" TargetType="Button">
            <Setter Property="Background"      Value="#313244"/>
            <Setter Property="Foreground"      Value="#CDD6F4"/>
            <Setter Property="BorderBrush"     Value="#585B70"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="12,0"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Height"          Value="30"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#45475A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#585B70"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource DarkButton}">
            <Setter Property="Background"  Value="#89B4FA"/>
            <Setter Property="Foreground"  Value="#1E1E2E"/>
            <Setter Property="BorderBrush" Value="#89B4FA"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B4D0FB"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#6A95D8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StopButton" TargetType="Button" BasedOn="{StaticResource DarkButton}">
            <Setter Property="Background"  Value="#F38BA8"/>
            <Setter Property="Foreground"  Value="#1E1E2E"/>
            <Setter Property="BorderBrush" Value="#F38BA8"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F7A8BE"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#D06A85"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Title-bar caption buttons ── -->
        <Style x:Key="CaptionButton" TargetType="Button">
            <Setter Property="Width"  Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Width="28" Height="28">
                            <Ellipse x:Name="Bg" Fill="Transparent" Stroke="#585B70" StrokeThickness="1.5"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Fill"   Value="#3A3A4E"/>
                                <Setter TargetName="Bg" Property="Stroke" Value="#7A7A9E"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Fill" Value="#2A2A3E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MinimizeButton" TargetType="Button">
            <Setter Property="Width"  Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Width="28" Height="28">
                            <Ellipse x:Name="Bg" Fill="Transparent" Stroke="#585B70" StrokeThickness="1.5"/>
                            <Line X1="9" Y1="14" X2="19" Y2="14"
                                  Stroke="#909090" StrokeThickness="1.5"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Fill"   Value="#3A3A4E"/>
                                <Setter TargetName="Bg" Property="Stroke" Value="#7A7A9E"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Fill" Value="#2A2A3E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButton" TargetType="Button">
            <Setter Property="Width"  Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Width="28" Height="28">
                            <Ellipse x:Name="Bg" Fill="Transparent" Stroke="#585B70" StrokeThickness="1.5"/>
                            <Path x:Name="X"
                                  Data="M 9,9 L 19,19 M 9,19 L 19,9"
                                  Stroke="#909090" StrokeThickness="1.5"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Fill"   Value="#C42B1C"/>
                                <Setter TargetName="Bg" Property="Stroke" Value="#C42B1C"/>
                                <Setter TargetName="X"  Property="Stroke" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Fill" Value="#9B1F13"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── TextBox ──────────────────────────────── -->
        <Style TargetType="TextBox">
            <Setter Property="Background"      Value="#1E1E2E"/>
            <Setter Property="Foreground"      Value="#CDD6F4"/>
            <Setter Property="CaretBrush"      Value="#CDD6F4"/>
            <Setter Property="BorderBrush"     Value="#585B70"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Height"          Value="30"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="8,0">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#89B4FA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── DataGrid ─────────────────────────────── -->
        <Style TargetType="DataGrid">
            <Setter Property="Background"               Value="#1E1E2E"/>
            <Setter Property="Foreground"               Value="#CDD6F4"/>
            <Setter Property="BorderBrush"              Value="#313244"/>
            <Setter Property="BorderThickness"          Value="0"/>
            <Setter Property="RowBackground"            Value="#1E1E2E"/>
            <Setter Property="AlternatingRowBackground" Value="#252535"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#313244"/>
            <Setter Property="VerticalGridLinesBrush"   Value="Transparent"/>
            <Setter Property="RowHeaderWidth"           Value="0"/>
            <Setter Property="SelectionMode"            Value="Single"/>
            <Setter Property="SelectionUnit"            Value="FullRow"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="#252535"/>
            <Setter Property="Foreground"      Value="#89B4FA"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Padding"         Value="10,6"/>
            <Setter Property="BorderBrush"     Value="#313244"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#3D3F5A"/>
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsMouseOver" Value="True"/>
                        <Condition Property="IsSelected"  Value="False"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="#2A2A3E"/>
                </MultiTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding"         Value="10,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#CDD6F4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Thin scrollbar ───────────────────────── -->
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>

                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width"    Value="10"/>
                    <Setter Property="MinWidth" Value="10"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type ScrollBar}">
                                <Grid Background="Transparent" Width="10">
                                    <Track x:Name="PART_Track" IsDirectionReversed="True">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}"
                                                          Opacity="0" IsTabStop="False"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb>
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="{x:Type Thumb}">
                                                        <Border x:Name="Thumb" Background="#585B70"
                                                                CornerRadius="3" Margin="2,0"/>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Thumb" Property="Background" Value="#89B4FA"/>
                                                            </Trigger>
                                                            <Trigger Property="IsDragging" Value="True">
                                                                <Setter TargetName="Thumb" Property="Background" Value="#6A95D8"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}"
                                                          Opacity="0" IsTabStop="False"/>
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>

                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height"    Value="8"/>
                    <Setter Property="MinHeight" Value="8"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type ScrollBar}">
                                <Grid Background="Transparent" Height="8">
                                    <Track x:Name="PART_Track">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Command="{x:Static ScrollBar.PageLeftCommand}"
                                                          Opacity="0" IsTabStop="False"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb>
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="{x:Type Thumb}">
                                                        <Border x:Name="Thumb" Background="#585B70"
                                                                CornerRadius="3" Margin="0,2"/>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Thumb" Property="Background" Value="#89B4FA"/>
                                                            </Trigger>
                                                            <Trigger Property="IsDragging" Value="True">
                                                                <Setter TargetName="Thumb" Property="Background" Value="#6A95D8"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Command="{x:Static ScrollBar.PageRightCommand}"
                                                          Opacity="0" IsTabStop="False"/>
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>

            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="38"/>   <!-- title bar   -->
            <RowDefinition Height="Auto"/> <!-- toolbar     -->
            <RowDefinition Height="5"/>    <!-- progress    -->
            <RowDefinition Height="*"/>    <!-- data grid   -->
            <RowDefinition Height="Auto"/> <!-- footer      -->
        </Grid.RowDefinitions>

        <!-- ══ Row 0: Custom title bar ══════════════════════════════ -->
        <Grid Grid.Row="0" Background="#181825">

            <!-- Logo + title (left) -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                <Viewbox Width="18" Height="18" Margin="0,0,8,0" ClipToBounds="True">
                    <Canvas Width="22" Height="22" ClipToBounds="True">
                        <Ellipse Canvas.Left="3" Canvas.Top="9" Width="4" Height="4" Fill="#89B4FA"/>
                        <Path Data="M 5,6 A 5,5 0 0 1 5,16"
                              Stroke="#89B4FA" StrokeThickness="1.8" Fill="Transparent"/>
                        <Path Data="M 5,3 A 8,8 0 0 1 5,19"
                              Stroke="#89B4FA" StrokeThickness="1.8" Fill="Transparent" Opacity="0.6"/>
                        <Path Data="M 5,0 A 11,11 0 0 1 5,22"
                              Stroke="#89B4FA" StrokeThickness="1.8" Fill="Transparent" Opacity="0.3"/>
                    </Canvas>
                </Viewbox>
                <TextBlock Text="N3tSc4n"
                           Foreground="#CDD6F4"
                           FontFamily="Consolas"
                           FontSize="14"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="VersionLabel"
                           Foreground="#45475A"
                           FontFamily="Consolas"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"/>
            </StackPanel>

            <!-- Window controls (right) -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        WindowChrome.IsHitTestVisibleInChrome="True"
                        Margin="0,0,10,0">
                <Button x:Name="BtnMinimize"
                        Style="{StaticResource MinimizeButton}"
                        ToolTip="Minimize"
                        Click="BtnMinimize_Click"
                        Margin="0,0,8,0"/>
                <Button x:Name="BtnMaximize"
                        Style="{StaticResource CaptionButton}"
                        ToolTip="Maximize"
                        Click="BtnMaximize_Click"
                        Margin="0,0,8,0">
                    <Path x:Name="MaximizeIcon"
                          Data="M 0,0 L 12,0 L 12,12 L 0,12 Z"
                          Stroke="#909090" StrokeThickness="1.5" Fill="Transparent"/>
                </Button>
                <Button x:Name="BtnClose"
                        Style="{StaticResource CloseButton}"
                        ToolTip="Close"
                        Click="BtnClose_Click"/>
            </StackPanel>
        </Grid>

        <!-- ══ Row 1: Toolbar ════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="#313244" Padding="12,8">
            <DockPanel>
                <!-- Left: subnet controls -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Subnet:"
                               Foreground="#CDD6F4"
                               FontSize="13"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <TextBox x:Name="SubnetBox"
                             Width="185"
                             FontFamily="Consolas"
                             FontSize="13"/>
                    <TextBlock Text=".0/24"
                               Foreground="#585B70"
                               FontSize="13"
                               FontFamily="Consolas"
                               VerticalAlignment="Center"
                               Margin="4,0,6,0"/>
                    <TextBlock x:Name="SubnetWarning"
                               Text="⚠"
                               Foreground="#F9E2AF"
                               FontSize="14"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"
                               Visibility="Collapsed"
                               Cursor="Help">
                        <TextBlock.ToolTip>
                            <ToolTip Background="#313244" BorderBrush="#585B70" Foreground="#CDD6F4">
                                <TextBlock MaxWidth="280" TextWrapping="Wrap" LineHeight="20">
                                    <Run FontWeight="SemiBold" Foreground="#F9E2AF">Different subnet than your own</Run>
                                    <LineBreak/>
                                    <Run>MAC addresses and vendor info will not be available — ARP only works within the same network segment.</Run>
                                    <LineBreak/>
                                    <Run Foreground="#A6E3A1">Ping, ports and hostname still work.</Run>
                                </TextBlock>
                            </ToolTip>
                        </TextBlock.ToolTip>
                    </TextBlock>
                    <Button x:Name="BtnScan"
                            Content="▶  Scan"
                            Style="{StaticResource AccentButton}"
                            Width="90"
                            Click="BtnScan_Click"/>
                    <Button x:Name="BtnStop"
                            Content="■  Stop"
                            Style="{StaticResource StopButton}"
                            Width="80"
                            IsEnabled="False"
                            Margin="6,0,0,0"
                            Click="BtnStop_Click"/>
                </StackPanel>

                <!-- Right: action buttons -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnWeb"
                            Content="🌐  Web"
                            Style="{StaticResource DarkButton}"
                            IsEnabled="False"
                            Click="BtnWeb_Click"/>
                    <Button x:Name="BtnRDP"
                            Content="🖥  RDP"
                            Style="{StaticResource DarkButton}"
                            IsEnabled="False"
                            Margin="6,0,0,0"
                            Click="BtnRDP_Click"/>
                    <Button x:Name="BtnSMB"
                            Content="🗂  SMB"
                            Style="{StaticResource DarkButton}"
                            IsEnabled="False"
                            Margin="6,0,0,0"
                            ToolTip="Open SMB share in file manager"
                            Click="BtnSMB_Click"/>
                    <Button x:Name="BtnCopy"
                            Content="📋  IP"
                            Style="{StaticResource DarkButton}"
                            IsEnabled="False"
                            Margin="6,0,0,0"
                            Click="BtnCopy_Click"/>
                    <Button x:Name="BtnExport"
                            Content="💾  Export"
                            Style="{StaticResource DarkButton}"
                            IsEnabled="False"
                            Margin="6,0,0,0"
                            ToolTip="Save scan as HTML"
                            Click="BtnExport_Click"/>
                </StackPanel>

                <!-- Middle: status -->
                <TextBlock x:Name="StatusText"
                           Text="Ready"
                           Foreground="#585B70"
                           FontSize="12"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Margin="16,0"/>
            </DockPanel>
        </Border>

        <!-- ══ Row 2: Progress bar ═══════════════════════════════════ -->
        <ProgressBar Grid.Row="2"
                     x:Name="PBar"
                     Minimum="0"
                     Maximum="254"
                     Value="0"
                     Foreground="#89B4FA"
                     Background="#252535"
                     BorderThickness="0"/>

        <!-- ══ Row 3: DataGrid ═══════════════════════════════════════ -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
            </Grid.ColumnDefinitions>
            <DataGrid Grid.Column="0"
                      x:Name="DGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserResizeRows="False"
                      CanUserSortColumns="True"
                      EnableRowVirtualization="True"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      ScrollViewer.VerticalScrollBarVisibility="Hidden"
                      SelectionChanged="DGrid_SelectionChanged"
                      MouseDoubleClick="DGrid_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="IP"       Binding="{Binding IP}"       Width="130" FontFamily="Consolas"/>
                    <DataGridTextColumn Header="Hostname" Binding="{Binding Hostname}" Width="200"/>
                    <DataGridTextColumn Header="MAC"      Binding="{Binding MAC}"      Width="145" FontFamily="Consolas"/>
                    <DataGridTextColumn Header="Vendor"   Binding="{Binding Vendor}"   Width="180"/>
                    <DataGridTextColumn Header="Ports"    Binding="{Binding Ports}"    Width="*"   FontFamily="Consolas" FontSize="11"/>
                </DataGrid.Columns>
            </DataGrid>
            <ScrollBar x:Name="DGridVScrollBar"
                       Grid.Column="1"
                       Orientation="Vertical"
                       Minimum="0" Maximum="0" SmallChange="1"
                       Visibility="Collapsed"/>
        </Grid>

        <!-- ══ Row 4: Footer ════════════════════════════════════════ -->
        <Border Grid.Row="4" Background="#181825" Padding="12,5">
            <TextBlock Text="Double-click → open web"
                       Foreground="#585B70"
                       FontSize="11"
                       HorizontalAlignment="Center"/>
        </Border>

    </Grid>
</Window>
